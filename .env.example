# Copy this file to .env and fill in real values. Never commit .env itself.

# From your Databricks workspace URL, e.g. adb-1234567890123456.7.azuredatabricks.net
# (just the hostname -- no https://, no trailing /?o=... query string)
DATABRICKS_HOST=adb-1780205232815035.15.azuredatabricks.net

# SQL Warehouses > (your warehouse) > Connection details > HTTP Path
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/f12edca7f36d2744

# No token needed -- auth is handled by an OAuth browser login the first time
# the app connects (same login you already use for the Databricks workspace).

# Full name of the voterfile table, e.g. main.voterfile.people
VOTERFILE_TABLE=illinois.deltatables.vcs_gold

# Table this app creates to hold the batch of people about to be scored
STAGING_TABLE=illinois.modeling.ipi_response_staging

# Table this app creates/appends to with every scored person + prediction
PREDICTIONS_TABLE=illinois.modeling.ipi_response_predictions

# MLflow registered model URI, e.g. models:/response_model/Production
MODEL_URI=models:/illinois.modeling.ipi_response_model@champion

# Run this once so MLflow can load the model:
#   databricks auth login --host https://<your-workspace-host> --profile DEFAULT
# (must be named "DEFAULT" -- MLflow's model-loading code only checks that
# literal profile name, not any custom name or the CLI's default_profile)
